# =============================================================================
# webnaprenajom.sk — environment template (safe to commit)
# =============================================================================
# Copy the block you need into a gitignored file:
#   .env.personal  — starý osobný Supabase projekt (záloha / legacy dev)
#   .env.team      — nový teamový Supabase projekt
#   .env           — aktívny default (voliteľné; npm run dev načíta .env)
#   .env.local     — per-PC override (načíta sa nad .env)
#
# NEVER commit: .env, .env.local, .env.personal, .env.team, service role keys
# See docs/supabase-migration.md for full migration runbook.
# =============================================================================

# --- Project refs (documentation only — not read by app) ---
# SUPABASE_PROJECT_REF_PERSONAL=kusluytpsgdrbhvaxoho
# SUPABASE_PROJECT_REF_TEAM=qosxlmrrkyvobjigsynt

# =============================================================================
# Frontend (required) — Vite + browser Supabase client
# =============================================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# Optional alias accepted by vite.config.ts:
# VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key

# Phase 5 promote execute guards (CLI only — never commit true in repo):
# MIGRATION_ALLOW_PROMOTE=true
# MIGRATION_APPROVED_BATCH=legacy_crm_2026_06_20

# =============================================================================
# Server-side / CLI only (never expose in browser, never commit real values)
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Legacy migration CLI (scripts/migration/) uses the same server-side vars above.

# =============================================================================
# Supabase Edge Functions — set in Supabase Dashboard → Edge Functions → Secrets
# (not in .env for production; listed here for operator reference)
# =============================================================================
# SUPABASE_ANON_KEY=           # same as publishable key
# SUPABASE_SERVICE_ROLE_KEY=   # dashboard → Settings → API
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# LOVABLE_API_KEY=

# =============================================================================
# Quick start (pick one)
# =============================================================================
# Personal (legacy):  cp .env.example .env.personal  → fill personal ref + keys
# Team (new):         cp .env.example .env.team       → fill team ref + keys
# Active dev (local default = team project in .env):
#   npm run dev              # uses .env (+ .env.local override)
#   npm run dev:team         # loads .env.team via Vite mode
#   npm run dev:personal     # loads .env.personal (legacy personal project)
