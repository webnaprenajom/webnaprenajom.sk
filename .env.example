# Environment template — copy to `.env` and fill in values.
# Do NOT commit `.env` (see RELEASE.md).
# Required for `npm run dev` and `npm run build` (vite.config.ts fails fast if missing).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# Optional alias accepted by vite.config.ts for the publishable key:
# VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key

# Legacy migration CLI (Phase 1 staging — server only, never commit)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
